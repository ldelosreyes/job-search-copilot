# Supabase Postgres connection string.
# Project Settings -> Database -> Connection string -> URI
# Use the "Transaction" pooler (port 6543) for serverless-friendly connections.
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Port the Hono API listens on locally.
PORT=3001

# Allowed CORS origin for the web app during local dev.
WEB_ORIGIN=http://localhost:5173

# Auth toggle (see api/src/middleware/auth.ts). Leave unset for the
# sandbox environment — no auth at all, matches the public demo. Only
# the production environment sets this to "true".
AUTH_ENABLED=false

# Only required when AUTH_ENABLED=true. Project Settings -> API.
# Use the anon/publishable key here, not the service-role key — this
# middleware only verifies a user's own token, no admin operations.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Static shared-secret gate for the sandbox environment specifically
# (see api/src/middleware/api-token.ts) — NOT the same as AUTH_ENABLED
# above. Leave unset locally/for no gate at all. When set, the web
# app's VITE_API_TOKEN must match exactly, or the sandbox frontend
# breaks (every request gets rejected).
API_TOKEN=
